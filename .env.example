# Copie este arquivo para .env e ajuste conforme necessario.
# cp .env.example .env

# --- Embeddings / Vector store (src/embeddings.py) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-base
CHROMA_COLLECTION=acervo_clinico

# --- RAG chain (src/rag_chain.py) ---
# Modelo LLM local via Ollama. Baixe antes com: ollama pull <modelo>
LLM_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0

# Quantidade de chunks recuperados por pergunta
RETRIEVER_K=4

# Distancia cosseno maxima aceitavel entre a pergunta e o chunk mais proximo
# (0 = identico, 2 = oposto). Perguntas fora desse limite sao recusadas antes
# de chamar o LLM. Ajustar durante a avaliacao (Semana 4) com
# eval/evaluate.py e eval/compare_chunking.py.
RETRIEVER_MAX_DISTANCE=0.45
